{
  "name": "impact",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "dev": "cd src && next dev",
    "build": "cd src && next build",
    "start": "cd src && next start",
    "lint": "eslint src/app src/integration_test",
    "test": "vitest run --config vitest.config.mts",
    "test:integration": "vitest run --config vitest.config.mts",
    "test:watch": "vitest --config vitest.config.mts",
    "typecheck": "tsc --noEmit -p src/tsconfig.json"
  },
  "dependencies": {
    "@google/genai": "^1.47.0",
    "@google/generative-ai": "^0.24.1",
    "@prisma/adapter-pg": "^7.6.0",
