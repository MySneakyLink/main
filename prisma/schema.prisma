// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`


// ==========================================
// ImpactTrail — Prisma Schema
// Community service gamification platform
// Database: Supabase PostgreSQL
// ==========================================

// --- ENUMS ---
// Fixed value sets enforced at the database level.

// User availability preferences
// enum Days { ... }

// Community service categories for quest/preference matching
// enum Worktype { ... }

// Preferred volunteering time blocks
// enum TimeSlots { ... }

// How users receive alerts (quest reminders, streak alerts, etc.)
// enum Notification { ... }

// Quest difficulty — used for both quest definition and user preference matching
// enum DifficultyScale { ... }

// Quest classification
// enum QuestType { ... }

// Seasonal availability window for quests
// enum Months { ... }

// --- CORE USER ---

// User — Central table. Linked to Supabase Auth via UserID (UUID).
// One-to-one: Records, Preference, Settings
// Many-to-many: Trophies (via UserTrophies), Quests (via UserQuestAssign),
//               Boss Quests (via RBUserQuestAssign)
// Self-relation: Friends (follower/following)

// Records — Tracks a user's lifetime stats (one-to-one with User)

// Preference — User's volunteering preferences for quest matching (one-to-one with User)
// Gemini uses these to personalize quest assignments.

// Settings — User's app settings like notifications and privacy (one-to-one with User)

// --- SOCIAL ---

// Friends — Self-referencing join table for follower/following relationships.
// @@unique prevents duplicate follow entries.
// Named relations ("Following"/"Follower") disambiguate the two User references.

// --- GAMIFICATION ---

// UserTrophies — Join table for many-to-many between User and Trophies.
// earnedDate auto-records when the trophy was awarded.
// @@unique prevents a user from earning the same trophy twice.

// Trophies — Trophy definitions. Image stored as URL (hosted in Supabase Storage).

// --- QUESTS ---

// Quests — AI-generated quests from community reports.
// Weight = priority score (increases when multiple reports flag the same issue).
// StartMonth/EndMonth = seasonal availability window.

// UserQuestAssign — Join table for many-to-many between User and Quests.
// Tracks assignment date, completion status, and completion time.
// CompletedTime is set by app code when Completed is toggled to true.

// --- BOSS QUESTS (RB = Registered Business/Organization) ---

// RBOrg — Partner organizations that host large-scale volunteer events.
// One-to-many with RBQuests (one org hosts many boss quests).

// RBQuests — Organization-hosted events (beach cleanups, food drives, etc.).
// Unlike regular quests, these have a specific Start datetime.

// RBUserQuestAssign — Join table for many-to-many between User and RBQuests.
// RSVP = when user signed up. Attended/AttendedTime track actual participation.

// --- REPORTS ---

// Reports — Community issues submitted by users, processed by Gemini API.
// UniqueReport = true if this report created a new quest, false if it matched existing.
// ReportQuest is optional (nullable) — starts null until Gemini processes and links a quest.


generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider  = "postgresql"
}


enum Days {
Monday
Teusday
Wednesday
Thursday
Friday
Saturday
Sunday
}

enum Worktype {
Environmental
Food
Homeless
}

enum TimeSlots {
EarlyMorning
LateMorning
Afternoon
EarlyEvening
LateEvening
}

enum Notification {
Text
Email
Push
}

enum DifficultyScale { /// For now, change it to something more fun.
easy
medium
hard
}

enum QuestType {
Daily
Normal
}

enum Months {
JANUARY
FEBRUARY
MARCH
APRIL
MAY
JUNE
JULY
AUGUST
SEPTEMBER
OCTOBER
NOVEMBER
DECEMBER
}

model User {
  UserID    String    @id @default(uuid()) 
  FName String 
  LName String
  Email String @unique
  College String?
  xp Int @default(0)
  Level Int @default(0)
  record Records?
  preference Preference?
  trophies UserTrophies[]
  following Friends[] @relation("Following")
  follower Friends[] @relation("Follower")
  setting Settings?
  quests UserQuestAssign[]
  rbquests RBUserQuestAssign[]
  reports Reports[]
}

model Records {
  RecID String @id @default(uuid())
  DailyQuestCompleted Int @default(0)
  DailyQuestAssign Int @default(0)
  QuestsCompleted Int @default(0)
  BossQuestCompleted Int @default(0)
  UserRec User @relation(fields: [UserRecID], references: [UserID])
  UserRecID String @unique
}


model Preference {
  PrefID String @id @default(uuid())
  PrefDay Days[] @default([])
  WorkType Worktype[] @default([])
  DistanceCommute Int?
  Location String?
  PrefTime TimeSlots[] @default([])
  UserPref User @relation(fields: [UserPrefID], references: [UserID])
  UserPrefID String @unique
}


model UserTrophies {
  UserTrophiesID String @id @default(uuid())
  earnedDate DateTime @default(now())
  UserTroph User @relation(fields: [UserTrophID], references: [UserID])
  UserTrophID String 
  trophies Trophies @relation(fields: [trophiesID],references: [TrophieID])
  trophiesID String 
  @@unique([UserTrophID, trophiesID])
}

model Trophies {
  TrophieID String @id @default(uuid())
  TrophieName String @unique
  XPRequired Int 
  ImageUrl String
  TrophieAssign UserTrophies[]
}

model Friends {
  FriendID String @id @default(uuid())
  FriendsCreated DateTime @default(now())
  Following User @relation("Following",fields: [FollowingID], references: [UserID])
  FollowingID String 
  Follower User @relation("Follower",fields: [FollowerID], references: [UserID])
  FollowerID String 
  @@unique([FollowingID, FollowerID])
}

model Settings {
  SettingsID String @id @default(uuid())
  UserSetting User @relation(fields: [UserSettingID], references: [UserID])
  UserSettingID String @unique
}

model UserQuestAssign {
  UserQuestAssignID String @id @default(uuid())
  AssignedDate DateTime @default(now())
  Completed Boolean @default(false)
  CompletedTime DateTime?
  UserQuest User @relation(fields: [UserQuestID], references: [UserID])
  UserQuestID String 
  QuestUser Quests @relation(fields: [QuestUserID],references: [QuestID])
  QuestUserID String 
}


model Quests {
  QuestID String @id @default(uuid())
  Name String @unique
  EstTime Int?
  XP Int
  Desc String
  Weight Int
  Blurb String
  Capacity Int
  Diff DifficultyScale
  Type QuestType
  StartMonth Months
  EndMonth Months
  QuestAssign UserQuestAssign[]
  ReportQuest Reports[]
}

model RBUserQuestAssign {
  UserQuestAssignID String @id @default(uuid())
  RSVP DateTime @default(now())
  Attended Boolean @default(false)
  AttendedTime DateTime?
  RBUserQuest User @relation(fields: [RBUserQuestID], references: [UserID])
  RBUserQuestID String 
  RBQuestUser RBQuests @relation(fields: [RBQuestUserID],references: [RBQuestID])
  RBQuestUserID String 
}


model RBQuests {
  RBQuestID String @id @default(uuid())
  Name String
  EstTime Int?
  XP Int
  Desc String
  Weight Int
  Start DateTime
  Capacity Int
  RBQuestOrg RBOrg @relation(fields: [RBQuestOrgID],references: [RBOrgID])
  RBQuestOrgID String 
  RBQuestAssign RBUserQuestAssign[]
}

model RBOrg {
  RBOrgID String @id @default(uuid())
  Name String
  Desc String
  Organizing RBQuests[]
}

model Reports {
  ReportID String @id @default(uuid())
  ReportCreatedAt DateTime @default(now())
  UserReport User @relation(fields: [UserReportID], references: [UserID])
  UserReportID String 
  UniqueReport Boolean @default(true)
  ReportQuest Quests? @relation(fields: [ReportQuestID], references: [QuestID])
  ReportQuestID String? 
}



