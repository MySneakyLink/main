// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}


model User {
  UserID    String    @id @default(uuid()) 
  FName String 
  LName String
  Email String @unique
  College String?
  xp Int @default(0)
  Level Int @default(0)
  record Record?
  preference Preference?
  trophies UserTrophies[]
  following Friends[] @relation("Following")
  follower Friends[] @relation("Follower")

}

model Record {
  RecID String @id @default(uuid())
  DailyQuestCompleted Int @default(0)
  DailyQuestAssign Int @default(0)
  QuestsCompleted Int @default(0)
  BossQuestCompleted Int @default(0)
  user User @relation(fields: [UserRec], references: [UserID])
  UserRec String @unique
}

enum Days {
Monday
Teusday
Wednesday
Thursday
Friday
Saturday
Sunday
}

enum Worktype {
Environmental
Food
Homeless
}

enum TimeSlots {
EarlyMorning
LateMorning
Afternoon
EarlyEvening
LateEvening
}

model Preference {
  PrefID String @id @default(uuid())
  PrefDay Days[] @default([])
  WorkType Worktype[] @default([])
  DistanceCommute Int?
  Location String?
  PrefTime TimeSlots[] @default([])
  user User @relation(fields: [UserPref], references: [UserID])
  UserPref String @unique
}


model UserTrophies {
  UserTrophID String @id @default(uuid())
  user User @relation(fields: [UserTroph], references: [UserID])
  UserTroph String 
  trophies Trophies @relation(fields: [troph],references: [TrophieID])
  troph String 
  earnedDate DateTime @default(now())
  @@unique([UserTroph, troph])
}

model Trophies {
  TrophieID String @id @default(uuid())
  TrophieAssign UserTrophies[]
  TrophieName String @unique
  XPRequired Int 
  ImageUrl String
}

model Friends {
  FriendID String @id @default(uuid())
  Following User @relation("Following",fields: [FollowingID], references: [UserID])
  FollowingID String @unique
  Follower User @relation("Follower",fields: [FollowerID], references: [UserID])
  FollowerID String @unique
  friendsCreated DateTime @default(now())
  @@unique([FollowingID, FollowerID])
}





